# =============================================================================
# Enterprise Retail Intelligence Platform — Environment Variables
# Phase 0: Local-first via Docker Compose only (no paid database services)
# =============================================================================

# --- PostgreSQL (Docker Compose) ---
POSTGRES_DB=retail_intelligence
POSTGRES_USER=retail_admin
POSTGRES_PASSWORD=retail_secure_pass
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=retail_intelligence
DATABASE_USERNAME=retail_admin
DATABASE_PASSWORD=retail_secure_pass

# Spring Boot JDBC URL
DATABASE_URL=jdbc:postgresql://localhost:5433/retail_intelligence

# Python SQLAlchemy-style URL
DATABASE_URL_PYTHON=postgresql://retail_admin:retail_secure_pass@localhost:5433/retail_intelligence

# --- Backend (Spring Boot) ---
SERVER_PORT=8080
JWT_SECRET=enterprise-retail-intelligence-jwt-secret-key-phase-0-minimum-256-bits-required
JWT_EXPIRATION_MS=86400000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DATA_SERVICE_URL=http://localhost:8000

# --- Data Service (FastAPI) ---
BACKEND_URL=http://localhost:8080
LOG_LEVEL=INFO

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8080
VITE_DATA_SERVICE_URL=http://localhost:8000

# --- Vercel Frontend (set in Vercel dashboard for production preview) ---
# VITE_API_URL=https://your-backend-url.example.com
# VITE_DATA_SERVICE_URL=https://your-data-service-url.example.com
